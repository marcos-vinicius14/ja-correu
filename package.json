{
  "name": "ja-correu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "backend:build": "cd apps/backend && ./mvnw clean package -DskipTests",
    "backend:run": "bash scripts/backend-run.sh",
    "backend:format": "cd apps/backend && ./mvnw com.diffplug.spotless:spotless-maven-plugin:apply",
    "frontend:dev": "cd apps/frontend && npm run start",
    "frontend:build": "cd apps/frontend && npm run build",
    "frontend:test": "cd apps/frontend && npm run test",
    "frontend:format": "cd apps/frontend && npx prettier --write .",
    "start": "bash scripts/start-all.sh",
    "dev": "run-p backend:run frontend:dev",
    "build": "run-s backend:build frontend:build",
    "test": "run-s frontend:test",
    "format": "run-s backend:format frontend:format",
    "fix": "run-s format"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}